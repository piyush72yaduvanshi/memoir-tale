rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }
    
    // Users collection - Admin management
    match /users/{userId} {
      // Users can read their own data
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow authenticated users to create their OWN user document (for first-time setup)
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Only admins can update/delete user roles (after initial setup)
      allow update, delete: if isAdmin();
    }
    
    // Inquiries collection (Contact Form Submissions)
    match /inquiries/{inquiryId} {
      // Anyone can create (public contact form) with required field validation
      allow create: if request.resource.data.keys().hasAll(['fullName', 'phone', 'email', 'createdAt']) &&
                       request.resource.data.fullName is string &&
                       request.resource.data.fullName.size() > 0 &&
                       request.resource.data.phone is string &&
                       request.resource.data.phone.size() > 0 &&
                       request.resource.data.email is string &&
                       request.resource.data.email.matches('.*@.*') &&
                       request.resource.data.createdAt is string;
      
      // Only admins can read, update, and delete
      allow read, update, delete: if isAdmin();
    }
    
    // Callbacks collection (Book Free Call Requests)
    match /callbacks/{callbackId} {
      // Anyone can create (public callback form) with required field validation
      allow create: if request.resource.data.keys().hasAll(['fullName', 'phone', 'createdAt']) &&
                       request.resource.data.fullName is string &&
                       request.resource.data.fullName.size() > 0 &&
                       request.resource.data.phone is string &&
                       request.resource.data.phone.size() > 0 &&
                       request.resource.data.createdAt is string;
      
      // Only admins can read, update, and delete
      allow read, update, delete: if isAdmin();
    }
    
    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
